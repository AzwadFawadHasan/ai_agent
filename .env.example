DJANGO_SECRET_KEY=change-me-for-local-dev
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Defaults to SQLite when DATABASE_URL / POSTGRES_* are not set.
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/codebase_research
# POSTGRES_DB=codebase_research
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432

REPOSITORY_STORAGE_DIR=./data/repositories

# auto = use Groq/OpenAI/Anthropic when a corresponding API key is set; otherwise use local Ollama if available; otherwise use heuristic mode.
# groq = use Groq OpenAI-compatible endpoint (tool calling supported).
# openai = use OpenAI API (tool calling supported).
# ollama = use local Ollama OpenAI-compatible endpoint (tool calling supported, no key).
# anthropic = use Anthropic Claude tool calling.
# heuristic = deterministic no-key mode for tests/demo fallback.
AGENT_PROVIDER=auto

# Groq (OpenAI-compatible)
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT_S=300
# For thinking-capable models on Ollama OpenAI-compat, disable thinking by default for speed.
# Options: high, medium, low, none
OLLAMA_REASONING_EFFORT=none

# OpenAI-compatible request controls (applies to Groq/OpenAI/Ollama; Ollama has its own override above).
OPENAI_COMPAT_TIMEOUT_S=60
LLM_MAX_TOKENS=700

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
AGENT_MAX_TOOL_CALLS=8
